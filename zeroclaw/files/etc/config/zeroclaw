config zeroclaw 'main'
	option enabled '0'
	option host '127.0.0.1'
	option port '42617'
	option allow_public_bind '0'
	option require_pairing '1'
	option provider 'openrouter'
	option api_base ''
	option model ''
	option api_key ''
	option temperature '0.7'
	option workspace '/var/lib/zeroclaw'
	option log_level 'info'
	option observability_backend 'log'
	option runtime_trace_mode 'none'
	option runtime_trace_path 'state/runtime-trace.jsonl'
	option runtime_trace_max_entries '200'
	option agent_max_tool_iterations '10'
	option agent_max_history_messages '50'
	option agent_parallel_tools '0'
	option memory_backend 'sqlite'
	option memory_auto_save '1'
